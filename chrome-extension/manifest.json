{
  "manifest_version": 3,
  "name": "Emoji & Symbols Copy and Paste + Lenny Face",
  "description": "Copy and paste 9500+ emojis, symbols & lenny faces ( ͡° ͜ʖ ͡°) in 1 click. The only extension with all 3 types!",
  "version": "1.0.1",
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Copy & paste 9500+ emojis, symbols, lenny faces",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+E",
        "mac": "Alt+Shift+E"
      },
      "description": "Open Emoji & Symbols popup"
    }
  },
  "permissions": ["storage"],
  "homepage_url": "https://emojisymbolscopy.com/chrome-extension",
  "minimum_chrome_version": "102",
  "content_security_policy": {
    "extension_pages": "default-src 'self'"
  }
}
